#bindsym #mod+Shift+s exec gnome-terminal -x bash -c 'nano ~/Desktop/i3keybindings.md'

# Pulse Audio controls
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume 1 +8% #increase sound volume
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume 1 -8% #decrease sound volume
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute 1 toggle # mute sound

# Sreen brightness controls
bindsym XF86MonBrightnessUp exec "light -A 100; notify-send 'brightness up'"
# increase screen brightness
bindsym XF86MonBrightnessDown exec "light -U 100; notify-send 'brightness down'"
# decrease screen brightness

